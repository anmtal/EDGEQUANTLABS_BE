# ─────────────────────────────────────────────────────────────
# EdgeQuantLabs License Server — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Email (SMTP)
# Recommended: Resend.com (free 3000 emails/month) or Brevo
# For Resend: host=smtp.resend.com, port=587, user=resend, pass=your_api_key
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Admin — used to deactivate licenses manually via /api/deactivate
# Make this long and random, e.g.: openssl rand -hex 32
ADMIN_SECRET=change_this_to_a_long_random_string

# Server port (Railway sets this automatically)
PORT=3000
